"""
strategy.py — THE THING BEING OPTIMIZED.

The agent (AI) modifies ONLY this file each iteration.
prepare.py calls generate_signals(df) and measures the result.

════════════════════════════════════════════════════════════
CONTRACT (DO NOT CHANGE THIS DOCSTRING):
  Input:  df — pd.DataFrame with columns:
              open, high, low, close, volume   (always present)
              oi   (open interest)             (present if available, else NaN column)
          index is a DatetimeIndex (daily or intraday bars)

  Output: pd.DataFrame with same index and at least two boolean columns:
              entry  : True on bars where we should go long
              exit   : True on bars where we should exit the long

  Optional output columns (used if present):
              short_entry : True on bars where we should go short
              short_exit  : True on bars where we should exit the short
════════════════════════════════════════════════════════════

AGENT FREEDOM — you may:
  ✓ Invent any indicator from raw OHLCV + OI math
  ✓ Combine any number of conditions
  ✓ Use machine-learning-style transformations (no sklearn import needed —
    pure numpy/pandas rolling math counts)
  ✓ Add helper functions freely
  ✓ Change every parameter
  ✓ Add short-side signals
  ✓ Use regime detection to switch sub-strategies
  ✓ Use OI to confirm / filter signals

AGENT CONSTRAINTS — you must NOT:
  ✗ Look ahead (no future data leakage — use .shift(1) when in doubt)
  ✗ Modify the generate_signals() signature
  ✗ Import anything outside stdlib / numpy / pandas

═══════════════════════════════════════════════════════════
TARGET: minimum 1 % gain per day on average
         (CAGR ≥ 1.01^252 ≈ 1200 % annualised)
         Practical milestones: Sharpe > 2, Sortino > 3, DD < 15 %
═══════════════════════════════════════════════════════════

Current iteration : 9
Best score so far : 3.7690

Iteration log:
  #0 | score=0.8552 | baseline: adaptive EMA + RSI momentum + OI divergence filter (with BankNifty 15m volume bypass & zero-OI fix)
  #1 | score=1.0180 | Increased ATR stop loss multiplier to 2.5
  #2 | score=1.8759 | Raised RSI entry upper bound to 70
  #3 | score=3.3246 | Optimized EMA fast/slow parameters to 5 and 13
  #8 | score=3.7550 | Raised RSI exit threshold to 95/100 (reduced premature exits)
  #9 | score=3.7690 | Removed macro trend filter (close > ema_trend) to trade counter-macro momentum sweeps
"""

from __future__ import annotations

import numpy as np
import pandas as pd


# ══════════════════════════════════════════════════════════════════════════════
# UTILITY — generic helpers the agent can call or replace freely
# ══════════════════════════════════════════════════════════════════════════════


def _sma(s: pd.Series, n: int) -> pd.Series:
    return s.rolling(n).mean()


def _ema(s: pd.Series, n: int) -> pd.Series:
    return s.ewm(span=n, adjust=False).mean()


def _rsi(s: pd.Series, n: int = 14) -> pd.Series:
    d = s.diff()
    g = d.clip(lower=0).ewm(com=n - 1, min_periods=n).mean()
    l = (-d.clip(upper=0)).ewm(com=n - 1, min_periods=n).mean()
    return 100 - 100 / (1 + g / l.replace(0, np.nan))


def _atr(df: pd.DataFrame, n: int = 14) -> pd.Series:
    hl = df["high"] - df["low"]
    hpc = (df["high"] - df["close"].shift()).abs()
    lpc = (df["low"] - df["close"].shift()).abs()
    tr = pd.concat([hl, hpc, lpc], axis=1).max(axis=1)
    return tr.ewm(com=n - 1, min_periods=n).mean()


def _macd(s: pd.Series, fast: int = 12, slow: int = 26, sig: int = 9):
    """Returns (macd_line, signal_line, histogram)."""
    m = _ema(s, fast) - _ema(s, slow)
    signal = _ema(m, sig)
    return m, signal, m - signal


def _bollinger(s: pd.Series, n: int = 20, std: float = 2.0):
    """Returns (upper, mid, lower)."""
    mid = _sma(s, n)
    band = s.rolling(n).std(ddof=0) * std
    return mid + band, mid, mid - band


def _stoch(df: pd.DataFrame, k: int = 14, d: int = 3):
    """Returns (%K, %D)."""
    lo = df["low"].rolling(k).min()
    hi = df["high"].rolling(k).max()
    pct_k = 100 * (df["close"] - lo) / (hi - lo).replace(0, np.nan)
    pct_d = _sma(pct_k, d)
    return pct_k, pct_d


def _adx(df: pd.DataFrame, n: int = 14) -> pd.Series:
    """Average Directional Index (trend strength, 0-100)."""
    atr = _atr(df, n)
    up   = df["high"].diff()
    down = -df["low"].diff()
    plus_dm  = np.where((up > down) & (up > 0), up, 0.0)
    minus_dm = np.where((down > up) & (down > 0), down, 0.0)
    plus_di  = 100 * pd.Series(plus_dm,  index=df.index).ewm(com=n-1, min_periods=n).mean() / atr
    minus_di = 100 * pd.Series(minus_dm, index=df.index).ewm(com=n-1, min_periods=n).mean() / atr
    dx = 100 * (plus_di - minus_di).abs() / (plus_di + minus_di).replace(0, np.nan)
    return dx.ewm(com=n - 1, min_periods=n).mean()


def _vwap_rolling(df: pd.DataFrame, n: int = 20) -> pd.Series:
    """Rolling VWAP over n bars."""
    tp = (df["high"] + df["low"] + df["close"]) / 3
    return (tp * df["volume"]).rolling(n).sum() / df["volume"].rolling(n).sum()


def _oi_delta(df: pd.DataFrame, n: int = 5) -> pd.Series:
    """
    OI change rate over n bars.
    Returns NaN column if 'oi' is missing or all-NaN.
    """
    if "oi" not in df.columns or df["oi"].isna().all():
        return pd.Series(np.nan, index=df.index)
    return df["oi"].pct_change(n)


def _price_oi_divergence(df: pd.DataFrame, n: int = 5) -> pd.Series:
    """
    Positive  → price up  + OI up   (bullish confirmation)
    Negative  → price up  + OI down (bearish divergence / short covering)
    Uses pct_change so it is scale-free.
    Returns NaN column when OI unavailable.
    """
    if "oi" not in df.columns or df["oi"].isna().all():
        return pd.Series(np.nan, index=df.index)
    price_chg = df["close"].pct_change(n)
    oi_chg    = df["oi"].pct_change(n)
    return price_chg * np.sign(oi_chg)  # sign alignment score


def _zscore(s: pd.Series, n: int = 20) -> pd.Series:
    mu  = s.rolling(n).mean()
    sig = s.rolling(n).std(ddof=0)
    return (s - mu) / sig.replace(0, np.nan)


def _regime(df: pd.DataFrame, n: int = 50) -> pd.Series:
    """
    Simple trend-regime detector.
    Returns: +1 (uptrend), -1 (downtrend), 0 (ranging)
    based on ADX and EMA slope.
    """
    adx = _adx(df, 14)
    ema = _ema(df["close"], n)
    slope = ema.pct_change(5)
    trending = adx > 20
    up   = trending & (slope > 0)
    down = trending & (slope < 0)
    regime = pd.Series(0, index=df.index)
    regime[up]   =  1
    regime[down] = -1
    return regime


# ══════════════════════════════════════════════════════════════════════════════
# STRATEGY PARAMETERS — agent tunes / replaces these every iteration
# ══════════════════════════════════════════════════════════════════════════════

# Trend / momentum
EMA_FAST   = 3
EMA_SLOW   = 12
EMA_TREND  = 55        # macro trend filter

# RSI
RSI_PERIOD   = 14
RSI_ENTRY_LO = 35      # enter only above this (momentum already building)
RSI_ENTRY_HI = 75      # don't chase overbought
RSI_EXIT_HI  = 90      # take profit on overbought

# MACD
MACD_FAST   = 5
MACD_SLOW   = 13
MACD_SIGNAL = 7

# Volume surge
VOL_MULT = 1.4         # entry bar volume must be > VOL_MULT × rolling avg

# ATR stop-loss
ATR_PERIOD   = 14
ATR_MULT_SL  = 3.0     # 0 = disabled

# Fixed exits
STOP_LOSS_PCT = 3.0
TAKE_PROFIT_PCT = 2.0
TRAILING_STOP_PCT = None
MAX_HOLD_BARS = None

# OI filters (only active when OI data is present)
OI_CONFIRM   = True    # require OI rising on entry
OI_LOOKBACK  = 3       # bars for OI change

# ADX trend filter
ADX_MIN = 0            # skip entries in directionless markets


# ══════════════════════════════════════════════════════════════════════════════
# MAIN FUNCTION — agent may change logic inside but NOT the signature
# ══════════════════════════════════════════════════════════════════════════════


def generate_signals(df: pd.DataFrame) -> pd.DataFrame:
    """
    Generate entry and exit signals.

    Args:
        df: OHLCV (+ optional OI) DataFrame with DatetimeIndex.
            Columns guaranteed: open, high, low, close, volume
            Optional column:    oi  (open interest; NaN if unavailable)

    Returns:
        DataFrame with same index, boolean columns:
            entry      — go long on this bar's OPEN
            exit       — close long on this bar's OPEN
            (optional) short_entry, short_exit
    """

    close  = df["close"]
    high   = df["high"]
    low    = df["low"]
    volume = df["volume"]

    has_oi = "oi" in df.columns and not df["oi"].isna().all() and not (df["oi"] == 0).all()
    has_vol = "volume" in df.columns and not (df["volume"] == 0).all() and not df["volume"].isna().all()

    # ── Indicators ──────────────────────────────────────────────────────────────

    ema_fast  = _ema(close, EMA_FAST)
    ema_slow  = _ema(close, EMA_SLOW)
    ema_trend = _ema(close, EMA_TREND)
    rsi       = _rsi(close, RSI_PERIOD)
    macd_line, macd_sig, macd_hist = _macd(close, MACD_FAST, MACD_SLOW, MACD_SIGNAL)
    atr       = _atr(df, ATR_PERIOD)
    adx       = _adx(df, 14)

    vol_surge = pd.Series(True, index=df.index)
    if has_vol:
        vol_avg = volume.rolling(20).mean()
        vol_surge = volume > (VOL_MULT * vol_avg)

    # OI indicators (gracefully degrade when absent)
    oi_rising = pd.Series(True, index=df.index)   # default: don't block
    if has_oi and OI_CONFIRM:
        oi_chg    = df["oi"].diff(OI_LOOKBACK)
        oi_rising = oi_chg > 0

    # ── Entry conditions ────────────────────────────────────────────────────────

    # 1. EMA stack: fast > slow
    ema_bull    = (ema_fast > ema_slow)

    # 2. EMA cross (golden cross on fast/slow)
    ema_cross   = (ema_fast > ema_slow) & (ema_fast.shift(1) <= ema_slow.shift(1))

    # 3. MACD momentum: histogram turning positive
    macd_turn   = (macd_hist > 0) & (macd_hist.shift(1) <= 0)

    # 4. RSI in momentum zone (not oversold, not overbought)
    rsi_zone    = (rsi > RSI_ENTRY_LO) & (rsi < RSI_ENTRY_HI)

    # 5. Volume surge confirms interest
    vol_surge_ok = vol_surge

    # 6. ADX confirms trend exists
    adx_ok      = adx > ADX_MIN

    # 7. OI confirmation (no-op when OI absent)
    oi_ok       = oi_rising

    # Composite entry: EMA cross OR MACD turn, filtered by trend/momentum/OI
    signal_trigger = ema_cross | macd_turn
    entry = signal_trigger & ema_bull & rsi_zone & vol_surge_ok & adx_ok & oi_ok

    # ── Exit conditions ─────────────────────────────────────────────────────────

    # 1. EMA death cross
    ema_bear    = (ema_fast < ema_slow) & (ema_fast.shift(1) >= ema_slow.shift(1))

    # 2. RSI overbought exhaustion
    rsi_ob      = rsi > RSI_EXIT_HI

    # 3. MACD histogram turning negative
    macd_fail   = (macd_hist < 0) & (macd_hist.shift(1) >= 0)

    # 4. Price drops below slow EMA (trend failed)
    below_slow  = close < ema_slow

    exit_sig = ema_bear | rsi_ob | macd_fail | below_slow

    # ── Optional: short signals (uncomment to enable) ───────────────────────────
    # Symmetric — only in downtrend (below trend EMA, fast < slow)
    # ema_bear_stack   = (ema_fast < ema_slow) & (close < ema_trend)
    # ema_death_cross  = (ema_fast < ema_slow) & (ema_fast.shift(1) >= ema_slow.shift(1))
    # short_entry = ema_death_cross & ema_bear_stack & (rsi > 40) & adx_ok
    # short_exit  = (ema_fast > ema_slow) | (rsi < 30)

    # ── Build output ────────────────────────────────────────────────────────────
    signals = pd.DataFrame(index=df.index)
    signals["entry"] = entry.fillna(False)
    signals["exit"]  = exit_sig.fillna(False)

    return signals
